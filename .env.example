# ── Database ────────────────────────────────────────────────────────────────
# MySQL connection string used by Prisma
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/adric_db"

# ── API ─────────────────────────────────────────────────────────────────────
# Port the Express server listens on (default 4000)
PORT=4000

# Secret for signing JWT tokens — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-secret"

# Token expiry (e.g. 8h, 1d)
JWT_EXPIRES_IN="8h"

# ── Web (Vite) ───────────────────────────────────────────────────────────────
# Base URL of the API, consumed by apps/web as import.meta.env.VITE_API_URL
VITE_API_URL="http://localhost:4000"

# ── Integrations (Stage 5+) ──────────────────────────────────────────────────
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
